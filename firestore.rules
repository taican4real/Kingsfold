rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens do not contain roles, we check the 'users' collection
    // We use exists() first to avoid errors on non-existent documents
    function isAdmin() { 
      return isSignedIn() && (
        (request.auth.token.email == 'taican4real@gmail.com') ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        )
      ); 
    }
    
    function isStaff() {
      return isSignedIn() && (
        (request.auth.token.email == 'taican4real@gmail.com') ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin', 'teacher', 'hod']
        )
      );
    }

    // Phase 4: Drafting the "Fortress" Rules
    match /users/{userId} {
      // Rule: Users can read their own profile. Admins can read all.
      // We use 'get' and 'list' separately for precision.
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isSignedIn();
      
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'role']) &&
               data.email is string && data.email.size() <= 200 &&
               data.role in ['student', 'parent', 'staff', 'admin', 'teacher', 'hod'];
      }

      // Rule: Creation
      allow create: if isSignedIn() && request.auth.uid == userId && 
                    (
                      incoming().role in ['student', 'teacher', 'hod'] || 
                      (incoming().email == 'taican4real@gmail.com' && incoming().role == 'admin') ||
                      (incoming().role == 'admin') // Allow admin sign up (portal logic checks limit)
                    ) &&
                    isValidUser(incoming());
                    
      // Rule: Action-Based Update Pattern
      allow update: if isSignedIn() && (
        // Action: User updates own profile
        (request.auth.uid == userId && 
         incoming().role == existing().role && 
         incoming().email == existing().email) ||
        
        // Action: Admin updates role or email
        (isAdmin() && isValidUser(incoming()))
      );

      // Rule: Deletion by Admin
      allow delete: if isAdmin();
    }

    match /cmsNodes/{nodeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
