# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="MY_APP_URL"

# AI Integration - Required for Lesson Planner
GEMINI_API_KEY=""

# Email Integration (SMTP) - Required for Student Registrations
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_EMAIL=""

# Google Maps Platform - Required for interactive school locator map
GOOGLE_MAPS_PLATFORM_KEY=""
